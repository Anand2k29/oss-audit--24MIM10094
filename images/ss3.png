<svg width="800" height="400" viewBox="0 0 800 400" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="400" rx="12" fill="#1e1e1e"/>
  <rect width="800" height="35" rx="12" fill="#333333"/>
  <circle cx="20" cy="17.5" r="6" fill="#ff5f56"/>
  <circle cx="40" cy="17.5" r="6" fill="#ffbd2e"/>
  <circle cx="60" cy="17.5" r="6" fill="#27c93f"/>
  <text x="400" y="22" font-family="monospace" font-size="14" fill="#ccc" text-anchor="middle">anand@ubuntu: ~/oss-audit/03_dir_audit.sh</text>
  
  <text x="20" y="70" font-family="monospace" font-size="16" fill="#fff">
    <tspan x="20" dy="1.2em" fill="#00ff00">anand@ubuntu:~/oss-audit$</tspan> ./03_dir_audit.sh
    <tspan x="20" dy="1.5em">--- Disk and Permission Auditor ---</tspan>
    <tspan x="20" dy="1.2em">Auditing important directories for open-source health.</tspan>
    <tspan x="20" dy="1.2em" fill="#27c93f">[EXISTS] /etc | Permissions: drwxr-xr-x | Size: 4.2M</tspan>
    <tspan x="20" dy="1.2em" fill="#27c93f">[EXISTS] /var/log | Permissions: drwxr-xr-x | Size: 18M</tspan>
    <tspan x="20" dy="1.2em" fill="#27c93f">[EXISTS] /usr/bin | Permissions: drwxr-xr-x | Size: 1.1G</tspan>
    <tspan x="20" dy="1.2em" fill="#27c93f">[EXISTS] /usr/lib/python3 | Permissions: drwxr-xr-x | Size: 92M</tspan>
    <tspan x="20" dy="1.2em" fill="#27c93f">[EXISTS] /tmp | Permissions: drwxrwxrwt | Size: 4.0K</tspan>
    <tspan x="20" dy="1.5em" fill="#555">----------------------------------------------------------</tspan>
    <tspan x="20" dy="1.2em">Audit Complete: Verified critical Python and Linux directories.</tspan>
  </text>
</svg>
